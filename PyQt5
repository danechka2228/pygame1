def move_to_right():
    n = listLeft.currentRow()
    item = listLeft.takeItem(n)
    listRight.addItem(item)  # перемещаем задачу в правый список


def move_to_left():
    c = listRight.currentRow()
    item = listRight.takeItem(c)
    listLeft.addItem(item)  # перемещаем задачу в левый список


