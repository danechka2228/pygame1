def create_db():
    connection = sqlite3.connect('dela.db')  # создаем файл
    cursor = connection.cursor()  # будт применяться все методы связанные с изменением БД
    cursor.execute(
        '''CREATE TABLE IF NOT EXISTS my_list(
        name TEXT,
        done INTEGER)'''
    )
    a = cursor.execute("SELECT name, done FROM my_list")
    print(cursor.fetchall())
    for pair in a:
        if pair[1] == 0:
            listLeft.addItem(pair[0])
        else:
            listRight.addItem(pair[0])
    connection.commit() # сохраняем БД
    connection.close()  # загружаем данные и закрываем


def add_ele(text):
    connection = sqlite3.connect('dela.db')
    cursor = connection.cursor()
    cursor.execute("INSERT INTO my_list(name, done) VALUES(?, ?)", (text, 0))
    connection.commit()
    connection.close()  # добавляем элемент в БД


