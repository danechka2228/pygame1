DB_NAME = 'dela.db'


def create_db():
    connection = sqlite3.connect(DB_NAME)
    cursor = connection.cursor()
    cursor.execute(
        '''CREATE TABLE IF NOT EXISTS my_list (
               name TEXT,
               done INTEGER
           )'''
    )
    connection.commit()

    cursor.execute("SELECT name, done FROM my_list")
    rows = cursor.fetchall()
    connection.close()

    for name, done in rows:
        if done == 0:
            listLeft.addItem(name)
        else:
            listRight.addItem(name)


def add_ele(name, done):
    connection = sqlite3.connect(DB_NAME)
    cursor = connection.cursor()
    cursor.execute(
        "INSERT INTO my_list (name, done) VALUES (?, ?)",
        (name, done)
    )
    connection.commit()
    connection.close()


def delete_from_db(name, done):
    connection = sqlite3.connect(DB_NAME)
    cursor = connection.cursor()
    cursor.execute(
        "DELETE FROM my_list WHERE name=? AND done=?",
        (name, done)
    )
    connection.commit()
    connection.close()


def clear_db():
    connection = sqlite3.connect(DB_NAME)
    cursor = connection.cursor()
    cursor.execute("DELETE FROM my_list")
    connection.commit()
    connection.close()


def err1(text):
    msg = QMessageBox()
    msg.setWindowTitle("Ошибка")
    msg.setText(text)
    msg.setIcon(QMessageBox.Warning)
    msg.exec_()


def addtask1():
    b = a.text().strip()
    if not b:
        err1("Введите название дела!")
        return

    listLeft.addItem(b)
    add_ele(b, 0)
    a.clear()


def addtask2():
    b = a.text().strip()
    if not b:
        err1("Введите название дела!")
        return

    listRight.addItem(b)
    add_ele(b, 1)
    a.clear()


def clear_all_left():
    if listLeft.count() == 0:
        err1("Список дел пуст!")
        return

    reply = QMessageBox.question(
        main_win,
        "Подтверждение",
        "Удалить все дела из списка дел?",
        QMessageBox.Yes | QMessageBox.No
    )
    if reply == QMessageBox.Yes:
        connection = sqlite3.connect(DB_NAME)
        cursor = connection.cursor()
        cursor.execute("DELETE FROM my_list WHERE done=0")
        connection.commit()
        connection.close()
        listLeft.clear()


def clear_all_right():
    if listRight.count() == 0:
        err1("Список сделанного пуст!")
        return

    reply = QMessageBox.question(
        main_win,
        "Подтверждение",
        "Удалить все из списка сделанного?",
        QMessageBox.Yes | QMessageBox.No
    )
    if reply == QMessageBox.Yes:
        connection = sqlite3.connect(DB_NAME)
        cursor = connection.cursor()
        cursor.execute("DELETE FROM my_list WHERE done=1")
        connection.commit()
        connection.close()
        listRight.clear()


def dci():
    row = listLeft.currentRow()
    if row < 0:
        err1("Выберите заметку!")
        return

    name = listLeft.currentItem().text()
    reply = QMessageBox.question(
        main_win,
        "Подтверждение",
        f"Удалить заметку \"{name}\"?",
        QMessageBox.Yes | QMessageBox.No
    )
    if reply == QMessageBox.Yes:
        delete_from_db(name, 0)
        listLeft.takeItem(row)


def dci2():
    row = listRight.currentRow()
    if row < 0:
        err1("Выберите заметку!")
        return

    name = listRight.currentItem().text()
    reply = QMessageBox.question(
        main_win,
        "Подтверждение",
        f"Удалить заметку \"{name}\"?",
        QMessageBox.Yes | QMessageBox.No
    )
    if reply == QMessageBox.Yes:
        delete_from_db(name, 1)
        listRight.takeItem(row)


def move_to_right():
    row = listLeft.currentRow()
    if row < 0:
        err1("Выберите заметку!")
        return

    item = listLeft.takeItem(row)
    name = item.text()
    listRight.addItem(name)
    delete_from_db(name, 0)
    add_ele(name, 1)


def move_to_left():
    row = listRight.currentRow()
    if row < 0:
        err1("Выберите заметку!")
        return

    item = listRight.takeItem(row)
    name = item.text()
    listLeft.addItem(name)
    delete_from_db(name, 1)
    add_ele(name, 0)


